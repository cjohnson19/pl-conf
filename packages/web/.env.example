# Submission route handler (app/api/submit) — set these in Vercel project env.

# Upstash Redis: rate limiting (5/hr/IP) + duplicate-URL detection (24h).
# Auto-populated by the Vercel Upstash integration; Redis.fromEnv() reads them.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Resend: submission notification email. Verify pl-conferences.com in Resend,
# then point SUBMISSION_EMAIL_SENDER at a sender on the verified domain.
RESEND_API_KEY=
SUBMISSION_EMAIL_SENDER=submissions@pl-conferences.com
NOTIFICATION_EMAIL=
